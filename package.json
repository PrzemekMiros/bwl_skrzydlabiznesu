{
  "scripts": {
    "build:css": "tailwindcss -i ./src/assets/css/input.css -o ./src/assets/css/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/assets/css/input.css -o ./src/assets/css/styles.css --watch",
    "build:site": "eleventy",
    "build": "npm run build:css && npm run build:site",
    "dev": "npm run build:css && concurrently \"eleventy --serve\" \"npm run watch:css\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  }
}
