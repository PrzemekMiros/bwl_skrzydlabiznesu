<section class="py-16" id="nominowane-firmy">
  <div class="mx-auto max-w-[1200px] px-6 md:px-24">
    <div class="mb-12 text-center">
      <h2 class="text-decor text-4xl font-semibold uppercase lg:text-6xl">Nominowane firmy</h2>
    </div>

    {% set companies = collections.nominatedCompanies | reverse %}
    {% if companies and companies[0] %}
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {% for company in companies %}
          <article class="rounded-sm border border-black/10 bg-white p-6 shadow-sm">
            {% set mappedCompanyImage = nominatedCompanyImagesBySlug[company.fileSlug] or nominatedCompanyImagesBySlug.default %}
            {% set companyImage = (company.data.companyImage or company.data.juryImage or mappedCompanyImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}
            {% if companyImage %}
              <a href="{{ company.url }}" class="mb-5 block overflow-hidden rounded-sm">
                <img src="{{ companyImage }}" alt="{{ company.data.title or company.fileSlug }}" class="h-[100px] w-full" loading="lazy" decoding="async" draggable="false" /> 
              </a>
            {% endif %}

            {% if company.data.excerpt %}
              <p class="mt-4 text-sm leading-6 text-black/80 line-clamp-2">{{ company.data.excerpt }}</p>
            {% endif %}
            <a class="mt-5 inline-block text-xs font-semibold uppercase tracking-[0.08em] text-[#0b0d1e] hover:text-[#d4ab71]" href="{{ company.url }}">
              Zobacz profil
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p class="text-center text-black/70">Brak opublikowanych wpisów.</p>
    {% endif %}
  </div>
</section>
