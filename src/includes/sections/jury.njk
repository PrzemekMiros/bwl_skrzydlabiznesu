<section id="jury" class="bg-gray-100 pt-16 pb-22">
  <div class="mx-auto max-w-[1200px] px-6 md:px-24">
    <div class="mb-8 text-center">
      <p class="mb-4 text-sm uppercase tracking-[0.2em] text-[#d4ab71]">Typ postu</p>
      <h2 class="text-decor text-4xl font-semibold uppercase lg:text-6xl">Jury</h2>
    </div>
  {% set members = collections.jury | reverse %}
  {% if members and members[0] %}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {% for member in members %}
        <article class="rounded-sm border border-black/10 bg-white p-6 shadow-sm">
          {% set memberImage = (member.data.juryImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}
          {% if memberImage %}
            <a href="{{ member.url }}" class="mb-5 block overflow-hidden rounded-sm">
              <img src="{{ memberImage }}" alt="{{ member.data.title }}" class="h-[320px] w-full object-cover object-top" loading="lazy" decoding="async" draggable="false" />
            </a>
          {% endif %}
          <h3 class="text-xl font-semibold text-[#0b0d1e]">
            <a href="{{ member.url }}" class="transition-colors hover:text-[#d4ab71]">{{ member.data.title }}</a>
          </h3>
          {% if member.data.excerpt %}
            <p class="mt-4 text-sm leading-6 text-black/80">{{ member.data.excerpt }}</p>
          {% endif %}
          <a class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.08em] text-[#0b0d1e] hover:text-[#d4ab71]" href="{{ member.url }}">
            Czytaj profil
          </a>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-black/70">Brak opublikowanych wpisow jury.</p>
  {% endif %}
  </div>
</section>
