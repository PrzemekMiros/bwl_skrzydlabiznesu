<section id="wywiady" class="py-16">
  <div class="mx-auto max-w-[1200px] px-6 md:px-24">
  <div class="mb-8 flex justify-center gap-4 text-center">
    <div>
      <h2 class="text-decor text-4xl font-semibold uppercase lg:text-6xl">Wywiady</h2>
    </div>
  </div>

  {% set interviews = collections.interviewsCollection %}
  {% if interviews %}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {% for interview in interviews %}
        {% if loop.index <= 6 %}
        <article class="rounded-sm border border-black/10 bg-white p-6 shadow-sm">
          {% set mappedInterviewImage = interviewImagesBySlug[interview.fileSlug] or interviewImagesBySlug.default %}
          {% set interviewImage = (interview.data.postImage or mappedInterviewImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}
          {% if interviewImage %}
            <a href="{{ interview.url }}" class="mb-5 block overflow-hidden rounded-sm">
              <img src="{{ interviewImage }}" alt="{{ interview.data.title }}" class="h-[220px] w-full object-cover" loading="lazy" decoding="async" draggable="false" />
            </a>
          {% endif %}
          <h3 class="text-xl font-semibold text-[#0b0d1e]">
            <a href="{{ interview.url }}" class="hover:text-[#d4ab71] transition-colors">{{ interview.data.title }}</a>
          </h3>
          {% if interview.data.person %}
            <p class="mt-2 text-sm uppercase tracking-[0.08em] text-black/60">{{ interview.data.person }}</p>
          {% endif %}
          {% if interview.data.excerpt %}
            <p class="mt-4 text-sm leading-6 text-black/80">{{ interview.data.excerpt }}</p>
          {% endif %}
          <a class="mt-5 inline-block text-sm font-semibold uppercase tracking-[0.08em] text-[#0b0d1e] hover:text-[#d4ab71]" href="{{ interview.url }}">
            Czytaj wywiad
          </a>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <p class="text-black/70">Brak opublikowanych wywiadów.</p>
  {% endif %}
  </div>
</section>
