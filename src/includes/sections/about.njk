<script>
  (function () {
    const root = document.querySelector("[data-about-slider]");
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-about-slide]"));
    const dotsWrap = root.querySelector("[data-about-dots]");
    if (!slides.length || !dotsWrap) return;

    let index = 0;
    let timer = null;
    let startX = 0;
    let dragging = false;

    function render() {
      slides.forEach((slide, i) => {
        slide.style.opacity = i === index ? "1" : "0";
      });
      dotsWrap.querySelectorAll("button").forEach((dot, i) => {
        dot.style.opacity = i === index ? "1" : "0.45";
        dot.setAttribute("aria-current", i === index ? "true" : "false");
      });
    }

    function goTo(nextIndex) {
      index = (nextIndex + slides.length) % slides.length;
      render();
    }

    function startAutoplay() {
      stopAutoplay();
      timer = setInterval(() => goTo(index + 1), 5000);
    }

    function stopAutoplay() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    slides.forEach((_, i) => {
      const dot = document.createElement("button");
      dot.type = "button";
      dot.className = "h-2.5 w-2.5 rounded-full bg-white transition-opacity";
      dot.setAttribute("aria-label", "Slajd " + (i + 1));
      dot.addEventListener("click", () => {
        goTo(i);
        startAutoplay();
      });
      dotsWrap.appendChild(dot);
    });

    root.addEventListener("pointerdown", (e) => {
      dragging = true;
      startX = e.clientX;
      stopAutoplay();
    });

    root.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      const delta = e.clientX - startX;
      dragging = false;
      if (Math.abs(delta) > 40) {
        goTo(delta < 0 ? index + 1 : index - 1);
      }
      startAutoplay();
    });

    root.addEventListener("pointerleave", () => {
      if (!dragging) return;
      dragging = false;
      startAutoplay();
    });

    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);

    render();
    startAutoplay();
  })();
</script>
