<section class="py-18 pb-24 bg-gray-100" id="nominowane-osobowosci">
  <div class="mx-auto max-w-[1400px] px-6 md:px-24">
    <div class="mb-12 text-center">
      <h2 class="text-decor text-4xl font-semibold uppercase lg:text-6xl">Nominowane osobowości</h2>
    </div>

    {% set nominees = collections.nominatedPersonalities | reverse %}
    {% if nominees and nominees[0] %}
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        {% for nominee in nominees %}
          <article class="rounded-sm border border-black/10 bg-white p-4 shadow-xs">
            {% set nomineeImage = (nominee.data.juryImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}
            {% if nomineeImage %}
              <a href="{{ nominee.url }}" class="mb-5 block overflow-hidden rounded-sm">
                <img src="{{ nomineeImage }}" alt="{{ nominee.data.title or nominee.fileSlug }}" class="h-[220px] w-full object-cover object-top" loading="lazy" decoding="async" draggable="false" />
              </a>
            {% endif %}
            <h3 class="text-xl font-semibold text-[#0b0d1e]">
              <a href="{{ nominee.url }}" class="transition-colors hover:text-[#d4ab71]">
                {{ nominee.data.title or nominee.fileSlug }}
              </a>
            </h3>
            <a class="mt-5 inline-block text-xs font-semibold uppercase tracking-[0.08em] text-[#0b0d1e] hover:text-[#d4ab71]" href="{{ nominee.url }}">
              Zobacz profil
            </a>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p class="text-center text-black/70">Brak opublikowanych wpisów.</p>
    {% endif %}
  </div>
</section>
