{% include "header.njk" %}
<main class="mx-auto max-w-[1200px] px-6 py-14 md:px-10">
  {% set juryImageSrc = (juryImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}

  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_420px] lg:gap-12">
    <section>
      <p class="text-sm uppercase tracking-[0.18em] text-[#d4ab71]">Jury</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight text-[#0b0d1e]">{{ title }}</h1>
      {% if excerpt %}
        <p class="mt-4 text-black/80">{{ excerpt }}</p>
      {% endif %}
      {% if person %}
        <p class="mt-3 text-sm uppercase tracking-[0.08em] text-black/60">{{ person }}</p>
      {% endif %}
      {% if role %}
        <p class="mt-1 text-sm text-black/70">{{ role }}</p>
      {% endif %}

      <article class="mt-10 max-w-none text-[17px] leading-[1.75] text-black/80 [&_h2]:mt-12 [&_h2]:mb-5 [&_h2]:text-3xl [&_h2]:font-semibold [&_h2]:leading-tight [&_h2]:text-[#0b0d1e] [&_h3]:mt-10 [&_h3]:mb-4 [&_h3]:text-2xl [&_h3]:font-medium [&_h3]:text-[#0b0d1e] [&_p]:my-5 [&_strong]:font-semibold [&_strong]:text-[#0b0d1e] [&_ul]:my-6 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-2 [&_a]:font-medium [&_a]:text-[#c59b52] [&_a]:underline [&_blockquote]:my-8 [&_blockquote]:border-l-4 [&_blockquote]:border-l-[#c59b52] [&_blockquote]:pl-6 [&_blockquote]:text-black/70">
        {{ content | safe }}
      </article>
    </section>

    {% if juryImageSrc %}
      <aside class="lg:sticky lg:top-[80px] lg:self-start">
        <img src="{{ juryImageSrc }}" alt="{{ title }}" class="h-auto w-full rounded-2xl object-cover" loading="lazy" decoding="async" draggable="false" />
      </aside>
    {% endif %}
  </div>
</main>
{% include "footer.njk" %}
