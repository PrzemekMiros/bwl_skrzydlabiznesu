{% include "header.njk" %}
<main class="mx-auto max-w-[900px] px-6 py-14">
  {% set mappedInterviewImage = interviewImagesBySlug[page.fileSlug] or interviewImagesBySlug.default %}
  {% set interviewImage = (postImage or mappedInterviewImage or "") | replace("/src/content/", "/content/") | replace("src/content/", "/content/") %}
  {% if interviewImage %}
    <img src="{{ interviewImage }}" alt="{{ title }}" class="mb-6 mx-auto h-auto w-full rounded-2xl object-cover" draggable="false" />
  {% endif %}
  <p class="text-sm uppercase tracking-[0.18em] text-[#d4ab71]">Wywiad</p>
  <h1 class="mt-3 text-4xl font-semibold leading-tight text-[#0b0d1e]">{{ title }}</h1>
  {% if person %}
    <p class="mt-3 text-sm uppercase tracking-[0.08em] text-black/60">{{ person }}</p>
  {% endif %}
  {% if role %}
    <p class="mt-1 text-sm text-black/70">{{ role }}</p>
  {% endif %}

  <article class="prose mt-10 max-w-none text-black/70">
    {{ content | safe }}
  </article>
</main>
{% include "footer.njk" %}
